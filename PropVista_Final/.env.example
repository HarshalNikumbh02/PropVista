DEBUG=True
SECRET_KEY=change-me-to-a-long-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Local development defaults to SQLite. Leave database variables blank if you do
# not have PostgreSQL installed.
DATABASE_URL=

# Optional PostgreSQL configuration. These are ignored when blank or when set
# to placeholders such as host/user/db/password.
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=5432

# Optional integrations. The app never crashes when these are blank.
GOOGLE_MAPS_API_KEY=
GEMINI_API_KEY=your_gemini_api_key_here
# Email SMTP Configurations
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=PropVista <noreply@propvista.com>



